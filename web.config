<?xml version="1.0" encoding="utf-8"?>
<!--
  Only needed if deploying to an Azure App Service on WINDOWS with the PHP
  extension installed (legacy option). Linux App Service (recommended, see
  docs/deployment-guide.md) ignores this file entirely.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>
    <staticContent>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
    <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>